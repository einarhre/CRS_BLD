+# Avoid false-positive Emscripten detection.
+# The previous compile test succeeded on non-Emscripten compilers
+# because the preprocessor could emit an empty translation unit.
+if(CMAKE_SYSTEM_NAME STREQUAL "Emscripten")
+  set(BROTLI_EMSCRIPTEN TRUE)
+else()
+  set(BROTLI_EMSCRIPTEN FALSE)
+endif()
 if (BROTLI_EMSCRIPTEN)
   message("-- Compiler is EMSCRIPTEN")
 else()
